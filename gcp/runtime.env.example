# Copy to a protected local file (never commit it), replace values, then upload each
# value to Google Secret Manager. The API, GKE worker, and migrations need these values.
DATABASE_URL=postgresql://spiderz:REPLACE_PASSWORD@PRIVATE_OR_CLOUDSQL_HOST:5432/spiderz
CREDENTIAL_ENCRYPTION_KEY=REPLACE_BASE64_32_BYTE_KEY
REDIS_HOST=REPLACE_MEMORSTORE_PRIVATE_IP
REDIS_PORT=6379
HOST=0.0.0.0
PORT=3000
WEBHOOK_SIGNING_SECRET=REPLACE_LONG_RANDOM_SECRET
JWT_SECRET=REPLACE_LONG_RANDOM_SECRET
CORS_ORIGIN=https://REPLACE_WITH_WEB_CLOUD_RUN_URL
BINARY_STORAGE_DRIVER=s3
BINARY_RETENTION_DAYS=30
S3_BUCKET=REPLACE_CLOUD_STORAGE_BUCKET
S3_REGION=us-central1
S3_ENDPOINT=https://storage.googleapis.com
S3_ACCESS_KEY_ID=REPLACE_GCS_HMAC_ACCESS_ID
S3_SECRET_ACCESS_KEY=REPLACE_GCS_HMAC_SECRET
GOOGLE_OAUTH_CLIENT_ID=REPLACE
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE
GOOGLE_OAUTH_REDIRECT_URI=https://REPLACE_API_HOST/api/oauth/google/callback

# Optional integrations: include all three values to enable an OAuth connector.
# SLACK_OAUTH_CLIENT_ID=
# SLACK_OAUTH_CLIENT_SECRET=
# SLACK_OAUTH_REDIRECT_URI=
# NOTION_OAUTH_CLIENT_ID=
# NOTION_OAUTH_CLIENT_SECRET=
# NOTION_OAUTH_REDIRECT_URI=
# AIRTABLE_OAUTH_CLIENT_ID=
# AIRTABLE_OAUTH_CLIENT_SECRET=
# AIRTABLE_OAUTH_REDIRECT_URI=
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_REDIRECT_URI=

!.env.*.example
*.pem
*.key
*.crt
*.p12
*.pfx

# Logs and process files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.pid.lock

# Local databases, backups, and uploads
*.sql.gz
*.dump
*.backup
*.sqlite
*.sqlite3
data/
uploads/

# Local Redis persistence
dump.rdb
appendonly.aof
appendonlydir/

# Editors and IDEs
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml

